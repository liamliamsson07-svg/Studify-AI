<title>Studify AI — Study Smarter, Feel Great</title>
<style>
  :root{
    --primary:#6C5CE7;
    --primary-dark:#5849c2;
    --accent:#00D2A0;
    --bg:#F6F5FF;
    --card:#ffffff;
    --text:#2D2A4A;
    --muted:#8b88a8;
    --warn:#FFB020;
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  html{ overflow-x:hidden; scroll-behavior:smooth; }
  .card{ scroll-margin-top:100px; }
  body{
    font-family:'Segoe UI',system-ui,-apple-system,sans-serif;
    background:
      radial-gradient(circle at 12% 18%, rgba(255,255,255,0.9) 0%, rgba(255,255,255,0) 8%),
      radial-gradient(circle at 30% 12%, rgba(255,255,255,0.75) 0%, rgba(255,255,255,0) 7%),
      radial-gradient(circle at 80% 8%, rgba(255,255,255,0.8) 0%, rgba(255,255,255,0) 9%),
      radial-gradient(circle at 65% 22%, rgba(255,255,255,0.6) 0%, rgba(255,255,255,0) 6%),
      linear-gradient(180deg, #8FD3F4 0%, #BFE9F5 30%, #E6F7FB 60%, #F6FBFF 100%);
    background-attachment:fixed;
    background-repeat:no-repeat;
    background-size:100% 100%;
    color:var(--text);
    min-height:100vh;
    overflow-x:hidden;
  }
  .cloud{
    position:fixed; pointer-events:none; z-index:0; opacity:0.9;
    filter:drop-shadow(0 6px 10px rgba(140,180,210,0.25));
  }
  header{
    display:flex; align-items:center; justify-content:space-between;
    padding:16px 40px;
    background:rgba(255,255,255,0.55);
    backdrop-filter:blur(10px);
    position:sticky; top:0; z-index:10;
    border-bottom:1px solid rgba(255,255,255,0.6);
    flex-wrap:wrap;
    gap:10px;
    row-gap:8px;
  }
  .logo{
    font-size:1.5rem; font-weight:800;
    display:flex; align-items:center; gap:8px;
  }
  .logo span{color:var(--primary);}
  .logo .ai-badge{
    background:linear-gradient(135deg,var(--primary),var(--accent));
    color:white; font-size:0.7rem; padding:3px 8px; border-radius:20px;
    font-weight:700; letter-spacing:0.5px;
  }
  nav{ display:flex; flex-wrap:wrap; align-items:center; }
  nav a{
    margin-left:24px; text-decoration:none; color:var(--text); font-weight:600; font-size:0.95rem;
    transition:color .2s;
  }
  nav a:hover{color:var(--primary);}

  .hero{
    text-align:center; padding:60px 20px 40px; position:relative; z-index:1;
  }
  .hero h1{
    font-size:2.6rem; font-weight:800; line-height:1.2;
    background:linear-gradient(135deg,var(--primary),var(--accent));
    -webkit-background-clip:text; background-clip:text; color:transparent;
  }
  .hero p{
    max-width:600px; margin:16px auto 0; color:var(--muted); font-size:1.1rem;
  }

  .container{
    max-width:1100px; margin:0 auto; padding:0 20px 60px;
    display:grid; grid-template-columns:1.3fr 1fr; gap:24px;
    position:relative; z-index:1;
  }
