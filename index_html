    "Every focused minute is a deposit into your future self. ✨",
    "Progress, not perfection. You've got this! 💪",
    "Small steps daily lead to big results. 🌟",
    "Your brain is getting stronger right now. 🧠",
    "Consistency beats intensity. Keep showing up! 🔥",
    "Future you is going to thank you for this. 🙌",
    "Focus is a superpower — you're using it well. ⚡",
    "You don't have to be perfect, just persistent. 🌱",
  ];

  function loadState(){
    try{
      const raw = localStorage.getItem(STORAGE_KEY);
      if(raw) return JSON.parse(raw);
    }catch(e){}
    return {
      points:0, sessions:0, minutes:0,
      streak:0, bestStreak:0, lastStudyDate:null,
      unlockedBadges:[], log:[],
      premium:false, homework:[], flashcards:[],
      progress:{ flashIndex:{}, summaryDrafts:{}, quizStats:{}, lastActive:{} },
      usage:{ windowStart: Date.now(), count: 0 }
    };
  }
  function saveState(){ localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); }

  let state = loadState();
  if(!state.progress) state.progress = { flashIndex:{}, summaryDrafts:{}, quizStats:{}, lastActive:{} };
  if(!state.progress.lastActive) state.progress.lastActive = {};
  if(!state.usage) state.usage = { windowStart: Date.now(), count: 0 };

  // ---------- Timer ----------
  let selectedMinutes = 25;
  let remainingSeconds = selectedMinutes*60;
  let timerInterval = null;
  let running = false;

  const timerDisplay = document.getElementById('timerDisplay');
  const startBtn = document.getElementById('startBtn');
  const resetBtn = document.getElementById('resetBtn');
  const modeBtns = document.querySelectorAll('.mode-btn');

  function formatTime(s){
    const m = Math.floor(s/60).toString().padStart(2,'0');
    const sec = (s%60).toString().padStart(2,'0');
    return `${m}:${sec}`;
  }
  function renderTimer(){ timerDisplay.textContent = formatTime(remainingSeconds); }

  modeBtns.forEach(btn=>{
    btn.addEventListener('click', ()=>{
      if(running) return;
      modeBtns.forEach(b=>b.classList.remove('active'));
      btn.classList.add('active');
      selectedMinutes = parseInt(btn.dataset.min);
      remainingSeconds = selectedMinutes*60;
      renderTimer();
    });
  });

  startBtn.addEventListener('click', ()=>{
    if(running){
      // pause
      clearInterval(timerInterval);
      running = false;
      startBtn.textContent = 'Resume';
      return;
    }
    running = true;
    startBtn.textContent = 'Pause';
    timerInterval = setInterval(()=>{
      remainingSeconds--;
      renderTimer();
      if(remainingSeconds<=0){
        clearInterval(timerInterval);
        running = false;
        startBtn.textContent = 'Start Studying';
        completeSession(selectedMinutes);
        remainingSeconds = selectedMinutes*60;
        renderTimer();
      }
    },1000);
  });

  resetBtn.addEventListener('click', ()=>{
    clearInterval(timerInterval);
    running = false;
    startBtn.textContent = 'Start Studying';
    remainingSeconds = selectedMinutes*60;
    renderTimer();
  });

  // ---------- Session / Streak logic ----------
  function todayStr(){ return new Date().toISOString().slice(0,10); }

  function updateStreak(){
    const today = todayStr();
    if(state.lastStudyDate === today) return; // already counted today
    const yesterday = new Date(Date.now()-86400000).toISOString().slice(0,10);
    if(state.lastStudyDate === yesterday){
      state.streak += 1;
    } else {
      state.streak = 1;
    }
    state.lastStudyDate = today;
    state.bestStreak = Math.max(state.bestStreak, state.streak);
  }

  function completeSession(minutes, subject){
    updateStreak();
    const earned = Math.round(minutes*1.5);
    state.points += earned;
    state.sessions += 1;
    state.minutes += minutes;
    state.log.unshift({subject: subject || 'Focus session', minutes, date:new Date().toLocaleString(), points:earned});
    state.log = state.log.slice(0,30);
    saveState();
    renderAll();
    showToast(`🎉 +${earned} points! Session complete. ${pickQuote()}`);
    checkBadges();
  }

  function logManualSession(){
    const input = document.getElementById('subjectInput');
    const subject = input.value.trim();
    if(!subject){ showToast('Type what you studied first! 📝'); return; }
    completeSession(25, subject);
    input.value='';
  }
  document.getElementById('logBtn').addEventListener('click', logManualSession);
  document.getElementById('subjectInput').addEventListener('keydown', e=>{ if(e.key==='Enter') logManualSession(); });

  function pickQuote(){
    return QUOTES[Math.floor(Math.random()*QUOTES.length)];
  }

  function checkBadges(){
    BADGES.forEach(b=>{
      if(state.unlockedBadges.includes(b.id)) return;
      let val = b.type==='points'?state.points : b.type==='sessions'?state.sessions : state.streak;
      if(val >= b.threshold){
        state.unlockedBadges.push(b.id);
        saveState();
        setTimeout(()=>showToast(`🏆 Badge unlocked: ${b.name}!`), 1200);
      }
    });
  }

  // ---------- Toast ----------
  let toastTimeout;
  function showToast(msg){
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('show');
    clearTimeout(toastTimeout);
    toastTimeout = setTimeout(()=>t.classList.remove('show'), 3500);
  }

  // ---------- Render ----------
  function renderStats(){
    document.getElementById('pointsNum').textContent = state.points;
    document.getElementById('sessionsNum').textContent = state.sessions;
    document.getElementById('minutesNum').textContent = state.minutes;
    document.getElementById('streakNum').textContent = state.streak;
    document.getElementById('bestStreakTag').textContent = `Best: ${state.bestStreak}`;
  }

  function renderProgress(){
    // find next locked badge by points
    const lockedPointBadges = BADGES.filter(b=>b.type==='points' && !state.unlockedBadges.includes(b.id))
      .sort((a,b)=>a.threshold-b.threshold);
    const next = lockedPointBadges[0];
    const fill = document.getElementById('progressFill');
    const label = document.getElementById('progressLabel');
    if(next){
      const prevThreshold = BADGES.filter(b=>b.type==='points' && state.unlockedBadges.includes(b.id))
        .reduce((max,b)=>Math.max(max,b.threshold),0);
      const pct = Math.min(100, ((state.points-prevThreshold)/(next.threshold-prevThreshold))*100);
      fill.style.width = pct+'%';
      label.textContent = `${state.points} / ${next.threshold} points to "${next.name}" ${next.icon}`;
    } else {
      fill.style.width = '100%';
      label.textContent = "You've unlocked every point badge! Legendary. 👑";
    }
  }

  function renderBadges(){
    const grid = document.getElementById('badgesGrid');
    grid.innerHTML = '';
    BADGES.forEach(b=>{
      const unlocked = state.unlockedBadges.includes(b.id);
      const div = document.createElement('div');
      div.className = 'badge' + (unlocked?' unlocked':'');
      div.innerHTML = `<div class="icon">${b.icon}</div><div class="name">${b.name}</div>`;
      grid.appendChild(div);
    });
  }

  function renderLog(){
    const list = document.getElementById('sessionList');
    if(state.log.length===0){
      list.innerHTML = '<li><span class="tag">No sessions yet — your log will appear here!</span></li>';
      return;
    }
    list.innerHTML = state.log.map(item=>`
      <li>
        <span><strong>${item.subject}</strong> · ${item.minutes} min</span>
        <span class="tag">${item.date} · +${item.points}pts</span>
      </li>
    `).join('');
  }

  function renderAll(){
    renderStats();
    renderProgress();
    renderBadges();
    renderLog();
    renderMyStudies();
    renderUsageBanner();
  }

  function renderMyStudies(){
    const list = document.getElementById('myStudiesList');
    if(!list) return;
    const groups = [{ id:null, label:'📚 General (no photo)' }, ...state.homework.map(h=>({ id:h.id, label:'📷 '+h.name }))];
    const rows = groups.map(g=>{
      const key = g.id || 'all';
      const cardCount = state.flashcards.filter(c=> (c.hwId||null) === g.id).length;
      const flashProgress = state.progress.flashIndex[key];
      const quiz = state.progress.quizStats[key];
      const summaries = (state.progress.savedSummaries && state.progress.savedSummaries[key]) ? state.progress.savedSummaries[key].length : 0;
      const hasActivity = cardCount>0 || quiz || summaries>0 || flashProgress!==undefined;
      if(!hasActivity) return null;
      const bits = [];
      if(cardCount>0) bits.push(`🗂️ ${flashProgress!==undefined? (flashProgress+1):1}/${cardCount} cards`);
      if(quiz && quiz.total>0) bits.push(`❓ ${quiz.correct}/${quiz.total} quiz correct`);
      if(summaries>0) bits.push(`📝 ${summaries} summary(ies)`);
      return `<li>
        <span><strong>${g.label}</strong><br><span class="tag">${bits.join(' · ') || 'Not started yet'}</span></span>
        <button class="btn btn-secondary" data-resume-hw="${g.id||''}" style="padding:6px 14px; font-size:0.8rem;">Resume</button>
      </li>`;
    }).filter(Boolean);
    list.innerHTML = rows.length ? rows.join('') : '<li><span class="tag">Nothing studied yet — start a session above and it will show up here!</span></li>';
    list.querySelectorAll('[data-resume-hw]').forEach(btn=>{
      btn.addEventListener('click', ()=>{
        const id = btn.dataset.resumeHw;
        selectedHwId = id || null;
        renderHomework();
        if(selectedHwId){
          const hw = state.homework.find(h=>h.id===selectedHwId);
          if(hw) document.getElementById('hwSelectedTag').textContent = `Studying: ${hw.name} — pick a method below 👇`;
        } else {
          document.getElementById('hwSelectedTag').textContent = 'Select a photo above, then pick a study method below to study it.';
        }
        const key = selectedHwId || 'all';
        let methodToOpen = 'flashcards';
        if(state.progress.quizStats[key] && state.progress.quizStats[key].total>0) methodToOpen = 'quiz';
        if(state.progress.savedSummaries && state.progress.savedSummaries[key] && state.progress.savedSummaries[key].length>0) methodToOpen = 'summary';
        if(state.progress.flashIndex[key]!==undefined) methodToOpen = 'flashcards';
        openMethod(methodToOpen);
        document.getElementById('methods').scrollIntoView({behavior:'smooth', block:'start'});
      });
    });
  }

  // ---------- Homework Upload ----------
  let selectedHwId = null;
  const hwInput = document.getElementById('hwInput');
  hwInput.addEventListener('change', (e)=>{
    const files = Array.from(e.target.files);
    files.forEach(file=>{
      const reader = new FileReader();
      reader.onload = ()=>{
        state.homework.push({ id: 'hw_'+Date.now()+Math.random().toString(36).slice(2,7), name:file.name, dataUrl: reader.result });
        saveState();
        renderHomework();
      };
      reader.readAsDataURL(file);
    });
    hwInput.value = '';
  });

  function renderHomework(){
    const grid = document.getElementById('hwGrid');
    grid.innerHTML = state.homework.map(hw=>`
      <div class="hw-item ${hw.id===selectedHwId?'selected':''}" data-id="${hw.id}">
        <img src="${hw.dataUrl}" alt="${hw.name}">
        <button class="del" data-del="${hw.id}">✕</button>
        <div class="name">${hw.name}</div>
      </div>
    `).join('');
    grid.querySelectorAll('.hw-item').forEach(el=>{
      el.addEventListener('click', (e)=>{
        if(e.target.dataset.del) return;
        selectedHwId = el.dataset.id;
        renderHomework();
        const hw = state.homework.find(h=>h.id===selectedHwId);
        document.getElementById('hwSelectedTag').textContent = `Studying: ${hw.name} — pick a method below 👇`;
      });
    });
    grid.querySelectorAll('[data-del]').forEach(btn=>{
      btn.addEventListener('click', (e)=>{
        e.stopPropagation();
        const id = btn.dataset.del;
        state.homework = state.homework.filter(h=>h.id!==id);
        if(selectedHwId===id) selectedHwId = null;
        saveState();
        renderHomework();
      });
    });
  }

  // ---------- Study Methods ----------
  let currentMethod = null; // null = no method open (exited state)
  const methodCards = document.querySelectorAll('.method-card');
  methodCards.forEach(card=>{
    card.addEventListener('click', ()=>{
      const isPremium = card.dataset.premium === 'true';
      if(isPremium && !state.premium){
        openPremiumModal();
        return;
      }
      openMethod(card.dataset.method);
    });
  });

  function scopeKey(){ return selectedHwId || 'all'; }

  function methodCardEl(method){
    return document.querySelector(`.method-card[data-method="${method}"]`);
  }

  function openMethod(method){
    saveCurrentDraft(); // persist whatever was in progress before switching
    methodCards.forEach(c=>c.classList.remove('active-method'));
    const card = methodCardEl(method);
    if(card) card.classList.add('active-method');
    currentMethod = method;
    state.progress.lastActive[method] = Date.now();
    saveState();
    renderStudyPanel();
  }

  function exitMethod(){
    saveCurrentDraft();
    currentMethod = null;
    methodCards.forEach(c=>c.classList.remove('active-method'));
    renderStudyPanel();
    showToast('💾 Progress saved! Jump back in anytime.');
  }

  // Saves any in-progress, unsaved input (e.g. a half-typed summary) before leaving a method
  function saveCurrentDraft(){
    if(currentMethod==='summary'){
      const box = document.getElementById('summaryText');
      if(box) state.progress.summaryDrafts[scopeKey()] = box.value;
      saveState();
    }
  }

  function exitButtonHtml(){
    return `<button class="btn btn-secondary" id="exitMethodBtn" style="float:right;">← Exit</button>`;
  }

  function currentDeck(){
    if(!selectedHwId) return state.flashcards;
    return state.flashcards.filter(c=>c.hwId===selectedHwId);
  }

  function renderStudyPanel(){
    const panel = document.getElementById('studyPanel');
    if(currentMethod===null){
      panel.innerHTML = `<p class="tag">Pick a study method above to begin. Your progress is always saved, so you can exit and resume anytime. 📚</p>`;
      return;
    }
    if(currentMethod==='flashcards'){
      renderFlashcardMethod(panel);
    } else if(currentMethod==='quiz'){
      renderQuizMethod(panel);
    } else if(currentMethod==='summary'){
      renderSummaryMethod(panel);
    } else if(currentMethod==='ai-flashcards'){
      renderAiFlashcardMethod(panel);
    } else if(currentMethod==='spaced-rep'){
      renderSpacedRepMethod(panel);
    }
    const exitBtn = document.getElementById('exitMethodBtn');
    if(exitBtn) exitBtn.addEventListener('click', exitMethod);
  }

  let flashShowBack = false;

  function renderFlashcardMethod(panel){
    const deck = currentDeck();
    const key = scopeKey();
    let flashIndex = state.progress.flashIndex[key] || 0;
    if(flashIndex>=deck.length) flashIndex = 0;
    panel.innerHTML = `
      ${exitButtonHtml()}
      <h3 style="margin-bottom:10px;">🗂️ Flashcards ${selectedHwId? '(for selected photo)':'(all)'}</h3>
      <div class="log-form">
        <input type="text" id="cardFront" placeholder="Question / term">
        <input type="text" id="cardBack" placeholder="Answer / definition">
        <button class="btn btn-secondary" id="addCardBtn">Add Card</button>
      </div>
      ${deck.length===0 ? '<p class="tag">No cards yet — add one above to start studying!</p>' : `
      <div class="flashcard" id="flashcardBox">${flashShowBack? deck[flashIndex].back : deck[flashIndex].front}</div>
      <div class="flash-controls">
        <button class="btn btn-secondary" id="prevCard">← Prev</button>
        <button class="btn btn-primary" id="flipCard">Flip</button>
        <button class="btn btn-secondary" id="nextCard">Next →</button>
      </div>
      <p class="tag" style="text-align:center; margin-top:8px;">Card ${flashIndex+1} / ${deck.length} · progress saved automatically</p>
      <div style="text-align:center; margin-top:10px;">
        <button class="btn btn-primary" id="finishFlash">I studied these! (+10 pts)</button>
      </div>
      `}
    `;
    document.getElementById('addCardBtn').addEventListener('click', ()=>{
      const f = document.getElementById('cardFront').value.trim();
      const b = document.getElementById('cardBack').value.trim();
      if(!f || !b){ showToast('Fill in both sides of the card! 🗂️'); return; }
      state.flashcards.push({front:f, back:b, hwId:selectedHwId});
      saveState();
      renderFlashcardMethod(panel);
    });
    if(deck.length>0){
      const setIndex = (i)=>{ state.progress.flashIndex[key] = i; saveState(); renderFlashcardMethod(panel); };
      document.getElementById('flashcardBox').addEventListener('click', ()=>{ flashShowBack=!flashShowBack; renderFlashcardMethod(panel); });
      document.getElementById('flipCard').addEventListener('click', ()=>{ flashShowBack=!flashShowBack; renderFlashcardMethod(panel); });
      document.getElementById('prevCard').addEventListener('click', ()=> setIndex((flashIndex-1+deck.length)%deck.length));
      document.getElementById('nextCard').addEventListener('click', ()=> setIndex((flashIndex+1)%deck.length));
      document.getElementById('finishFlash').addEventListener('click', ()=> awardStudyPoints('Flashcards', 10));
    }
  }

  function getQuizStats(key){
    if(!state.progress.quizStats[key]) state.progress.quizStats[key] = {correct:0, total:0};
    return state.progress.quizStats[key];
  }

  function renderQuizMethod(panel){
    const deck = currentDeck();
    const key = scopeKey();
    const stats = getQuizStats(key);
    if(deck.length<2){
      panel.innerHTML = `${exitButtonHtml()}<h3>❓ Practice Quiz</h3><p class="tag">Add at least 2 flashcards first — the quiz is built from them!</p>`;
      return;
    }
    const q = deck[Math.floor(Math.random()*deck.length)];
    let options = [q.back];
    while(options.length<Math.min(4,deck.length)){
      const rand = deck[Math.floor(Math.random()*deck.length)].back;
      if(!options.includes(rand)) options.push(rand);
    }
    options.sort(()=>Math.random()-0.5);
    panel.innerHTML = `
      ${exitButtonHtml()}
      <h3 style="margin-bottom:10px;">❓ Practice Quiz</h3>
      <p class="tag" style="display:block; margin-bottom:8px;">Score so far: ${stats.correct}/${stats.total} correct</p>
      <div class="quiz-q">${q.front}</div>
      ${options.map(o=>`<button class="quiz-opt" data-correct="${o===q.back}">${o}</button>`).join('')}
      <div style="text-align:center; margin-top:14px;"><button class="btn btn-secondary" id="nextQuiz">Next Question</button></div>
    `;
    panel.querySelectorAll('.quiz-opt').forEach(btn=>{
      btn.addEventListener('click', ()=>{
        const correct = btn.dataset.correct==='true';
        panel.querySelectorAll('.quiz-opt').forEach(b=>b.disabled=true);
        btn.classList.add(correct?'correct':'wrong');
        stats.total += 1;
        if(correct){ stats.correct += 1; saveState(); awardStudyPoints('Quiz', 8); }
        else { saveState(); showToast('Not quite — review that card and try again! 💪'); }
      });
    });
    document.getElementById('nextQuiz').addEventListener('click', ()=>renderQuizMethod(panel));
  }

  function renderSummaryMethod(panel){
    const key = scopeKey();
    const draft = state.progress.summaryDrafts[key] || '';
    panel.innerHTML = `
      ${exitButtonHtml()}
      <h3 style="margin-bottom:10px;">📝 Summarize & Teach (Feynman Technique)</h3>
      <p class="tag" style="margin-bottom:8px; display:block;">Explain what you learned in your own words, like you're teaching a friend.</p>
      <textarea class="summary-box" id="summaryText" placeholder="Today I learned...">${draft}</textarea>
      <div style="text-align:center; margin-top:12px;">
        <button class="btn btn-primary" id="saveSummary">Save Summary (+12 pts)</button>
      </div>
    `;
    const box = document.getElementById('summaryText');
    box.addEventListener('input', ()=>{ state.progress.summaryDrafts[key] = box.value; saveState(); });
    document.getElementById('saveSummary').addEventListener('click', ()=>{
      const text = box.value.trim();
      if(text.length<10){ showToast('Write a bit more detail first! ✍️'); return; }
      if(!state.progress.savedSummaries) state.progress.savedSummaries = {};
      if(!state.progress.savedSummaries[key]) state.progress.savedSummaries[key] = [];
      state.progress.savedSummaries[key].push({text, date:new Date().toLocaleString()});
      state.progress.summaryDrafts[key] = '';
      awardStudyPoints('Summary', 12, text.slice(0,60)+(text.length>60?'…':''));
      box.value='';
    });
  }

  function renderAiFlashcardMethod(panel){
    const hw = state.homework.find(h=>h.id===selectedHwId);
    panel.innerHTML = `
      ${exitButtonHtml()}
      <h3 style="margin-bottom:10px;">✨ AI Flashcards from Photo <span class="premium-tag" style="position:static; display:inline-block;">PREMIUM</span></h3>
      ${!hw ? '<p class="tag">Select a homework photo above first, then generate cards from it.</p>' : `
      <p class="tag" style="display:block; margin-bottom:10px;">Photo: ${hw.name}</p>
      <input type="text" id="aiTopic" class="summary-box" style="min-height:auto; padding:12px;" placeholder="Briefly describe the topic/content in this photo (e.g. 'Cell mitosis stages')">
      <div style="text-align:center; margin-top:12px;">
        <button class="btn btn-primary" id="genAiCards">Generate 5 Flashcards ✨</button>
      </div>
      `}
    `;
    if(hw){
      document.getElementById('genAiCards').addEventListener('click', ()=>{
        const topic = document.getElementById('aiTopic').value.trim() || 'this topic';
        const templates = [
          [`What is the main idea of ${topic}?`, `The core concept covered in your notes on ${topic}.`],
          [`Define a key term from ${topic}.`, `Write the definition from your homework photo here.`],
          [`Give one example related to ${topic}.`, `An example pulled from your notes.`],
          [`Why does ${topic} matter?`, `The significance / real-world application.`],
          [`Summarize ${topic} in one sentence.`, `A one-line takeaway from your homework.`],
        ];
        templates.forEach(([f,b])=> state.flashcards.push({front:f, back:b, hwId:hw.id}));
        saveState();
        showToast('✨ 5 AI flashcards generated! Head to Flashcards to study them.');
        awardStudyPoints('AI Flashcards', 15);
      });
    }
  }

  function renderSpacedRepMethod(panel){
    const deck = state.flashcards;
    const days = ['Today','+1 day','+3 days','+7 days','+14 days','+30 days'];
    panel.innerHTML = `
      ${exitButtonHtml()}
      <h3 style="margin-bottom:10px;">📅 Spaced Repetition Planner <span class="premium-tag" style="position:static; display:inline-block;">PREMIUM</span></h3>
      ${deck.length===0? '<p class="tag">Add some flashcards first, then we\'ll build your optimal review schedule.</p>' : `
      <p class="tag" style="display:block; margin-bottom:10px;">Based on the forgetting curve, review your ${deck.length} card(s) on these days:</p>
      <ul class="session-list">
        ${days.map(d=>`<li><span>📆 ${d}</span><span class="tag">Review all ${deck.length} cards</span></li>`).join('')}
      </ul>
      <div style="text-align:center; margin-top:12px;">
        <button class="btn btn-primary" id="confirmPlan">Start This Plan (+10 pts)</button>
      </div>
      `}
    `;
    if(deck.length>0){
      document.getElementById('confirmPlan').addEventListener('click', ()=> awardStudyPoints('Spaced Repetition Plan', 10));
    }
  }

  const DAILY_FREE_LIMIT = 2;
  const DAY_MS = 24*60*60*1000;

  function refreshUsageWindow(){
    if(Date.now() - state.usage.windowStart >= DAY_MS){
      state.usage.windowStart = Date.now();
      state.usage.count = 0;
      saveState();
    }
  }

  function usageRemaining(){
    refreshUsageWindow();
    return Math.max(0, DAILY_FREE_LIMIT - state.usage.count);
  }

  function usageResetInHours(){
    const msLeft = DAY_MS - (Date.now() - state.usage.windowStart);
    return Math.max(0, Math.ceil(msLeft/3600000));
  }

  function canStartStudySession(){
    if(state.premium) return true;
    return usageRemaining() > 0;
  }

  function renderUsageBanner(){
    const el = document.getElementById('usageBanner');
    if(!el) return;
    if(state.premium){
      el.textContent = '👑 Premium active — unlimited study sessions every day!';
      el.style.background = 'linear-gradient(135deg,#FFF9EC,#FFF3D6)';
      el.style.color = 'var(--primary-dark)';
      return;
    }
    const remaining = usageRemaining();
    el.style.background = '#F7F6FF';
    if(remaining>0){
      el.textContent = `⏳ ${remaining} of ${DAILY_FREE_LIMIT} free study session${DAILY_FREE_LIMIT>1?'s':''} left today. Upgrade to Premium for unlimited studying ✨`;
    } else {
      el.textContent = `🔒 You've used all ${DAILY_FREE_LIMIT} free study sessions today. Come back in ${usageResetInHours()}h, or go Premium for unlimited access ✨`;
    }
  }

  function awardStudyPoints(label, pts, note){
    if(!canStartStudySession()){
      showToast(`⏳ You've used your ${DAILY_FREE_LIMIT} free study sessions for today. Upgrade to Premium for unlimited studying!`);
      openPremiumModal();
      return;
    }
    if(!state.premium){
      refreshUsageWindow();
      state.usage.count += 1;
    }
    updateStreak();
    state.points += pts;
    state.sessions += 1;
    state.log.unshift({subject: note? `${label}: ${note}` : label, minutes:0, date:new Date().toLocaleString(), points:pts});
    state.log = state.log.slice(0,30);
    saveState();
    renderAll();
    renderUsageBanner();
    if(!state.premium && usageRemaining()===0){
      setTimeout(()=>showToast(`🎉 +${pts} points! That was your last free session today — come back in ${usageResetInHours()}h or go Premium for unlimited access.`), 200);
    } else {
      showToast(`🎉 +${pts} points! ${pickQuote()}`);
    }
    checkBadges();
  }

  // ---------- Premium ----------
  const premiumModal = document.getElementById('premiumModal');
  function openPremiumModal(){ premiumModal.classList.add('show'); }
  function closePremiumModal(){ premiumModal.classList.remove('show'); }
  document.getElementById('premiumNavBtn').addEventListener('click', ()=>{
    if(state.premium){ showToast('✨ You\'re already Premium! Enjoy all study methods.'); return; }
    openPremiumModal();
  });
  document.getElementById('closeModal').addEventListener('click', closePremiumModal);
  premiumModal.addEventListener('click', (e)=>{ if(e.target===premiumModal) closePremiumModal(); });
  document.getElementById('subscribeBtn').addEventListener('click', ()=>{
    // Demo-mode subscription toggle. Wire this button to a real payment
    // processor (e.g. Stripe Checkout) to charge $2.99/month for real.
    state.premium = true;
    saveState();
    closePremiumModal();
    unlockPremiumMethods();
    renderUsageBanner();
    showToast('👑 Welcome to Premium! Unlimited studying + AI Flashcards & Spaced Repetition unlocked.');
  });
  function unlockPremiumMethods(){
    document.querySelectorAll('.method-card[data-premium="true"]').forEach(c=>{
      c.classList.remove('locked');
      const tag = c.querySelector('.premium-tag');
      if(tag) tag.textContent = 'UNLOCKED';
    });
    document.getElementById('premiumNavBtn').textContent = '👑 Premium';
  }

  // ---------- Nav tab scrolling (fixes sticky header covering target sections) ----------
  document.querySelectorAll('nav a[href^="#"]').forEach(link=>{
    link.addEventListener('click', (e)=>{
      e.preventDefault();
      const targetId = link.getAttribute('href').slice(1);
      const target = document.getElementById(targetId);
      if(!target) return;
      const header = document.querySelector('header');
      const headerHeight = header ? header.offsetHeight : 0;
      const top = target.getBoundingClientRect().top + window.pageYOffset - headerHeight - 16;
      window.scrollTo({ top, behavior:'smooth' });
    });
  });

  document.getElementById('quoteBox').textContent = `"${pickQuote()}"`;
  renderTimer();
  renderAll();
  renderHomework();
  renderStudyPanel();
  if(state.premium) unlockPremiumMethods();
  renderUsageBanner();
  checkBadges();
</script>
</body>
</html>
