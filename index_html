  /* ---------- Mobile-friendly adjustments ---------- */
  @media (max-width:640px){
    header{ padding:14px 18px; justify-content:center; text-align:center; }
    .logo{ font-size:1.25rem; }
    nav{ justify-content:center; width:100%; }
    nav a{ margin:0 10px; font-size:0.85rem; }
    #premiumNavBtn{ width:100%; margin-top:6px; }
    .hero{ padding:36px 16px 24px; }
    .hero h1{ font-size:1.7rem; }
    .hero p{ font-size:0.95rem; }
    .container{ padding:0 12px 40px; gap:16px; }
    .card{ padding:18px; border-radius:16px; }
    .timer-display{ font-size:3rem; }
    .timer-modes{ gap:8px; }
    .mode-btn{ padding:7px 12px; font-size:0.8rem; }
    .timer-controls{ flex-direction:column; align-items:stretch; }
    .btn{ width:100%; }
    .stats-grid{ gap:8px; }
    .stat-box{ padding:12px 6px; }
    .stat-box .num{ font-size:1.4rem; }
    .badges-grid{ grid-template-columns:repeat(3,1fr); }
    .log-form{ flex-direction:column; }
    .log-form input, .log-form button{ width:100%; }
    .hw-grid{ grid-template-columns:repeat(3,minmax(70px,1fr)); }
    .modal-box{ padding:22px; }
    .price-tag{ font-size:1.8rem; }
    .cloud{ display:none; }
  }
  @media (max-width:400px){
    .badges-grid{ grid-template-columns:repeat(2,1fr); }
    .hw-grid{ grid-template-columns:repeat(2,minmax(70px,1fr)); }
  }

  .card{
    background:var(--card); border-radius:20px; padding:28px;
    box-shadow:0 8px 30px rgba(108,92,231,0.08);
    margin-bottom:24px;
  }
  .card h2{ font-size:1.3rem; margin-bottom:16px; }

  /* Timer */
  .timer-display{
    font-size:4.5rem; font-weight:800; text-align:center; letter-spacing:2px;
    color:var(--primary-dark); margin:10px 0 20px;
    font-variant-numeric:tabular-nums;
  }
  .timer-modes{ display:flex; justify-content:center; gap:10px; margin-bottom:20px; flex-wrap:wrap;}
  .mode-btn{
    padding:8px 16px; border-radius:30px; border:2px solid #E3E1FF; background:white;
    cursor:pointer; font-weight:600; color:var(--text); transition:.2s;
  }
  .mode-btn.active, .mode-btn:hover{ background:var(--primary); color:white; border-color:var(--primary);}
  .timer-controls{ display:flex; justify-content:center; gap:14px; }
  .btn{
    padding:12px 28px; border-radius:30px; border:none; font-weight:700; font-size:1rem;
    cursor:pointer; transition:transform .15s, box-shadow .15s;
  }
  .btn-primary{ background:linear-gradient(135deg,var(--primary),#8a7bf0); color:white; box-shadow:0 6px 16px rgba(108,92,231,0.35);}
  .btn-secondary{ background:#F0EEFF; color:var(--primary-dark); }
  .btn:hover{ transform:translateY(-2px); }
  .btn:active{ transform:translateY(0); }

  /* Stats */
  .stats-grid{ display:grid; grid-template-columns:repeat(3,1fr); gap:14px; margin-bottom:10px;}
  .stat-box{
    background:linear-gradient(135deg,#F7F6FF,#EFF0FF); border-radius:14px; padding:16px; text-align:center;
  }
  .stat-box .num{ font-size:1.8rem; font-weight:800; color:var(--primary-dark);}
  .stat-box .label{ font-size:0.8rem; color:var(--muted); margin-top:4px;}

  /* Streak flame row */
  .streak-row{ display:flex; align-items:center; gap:10px; margin-top:10px; }
  .flame{ font-size:1.6rem; }

  /* Progress bar to next badge */
  .progress-wrap{ margin-top:14px; }
  .progress-bar-bg{ width:100%; height:12px; background:#EDEBFF; border-radius:10px; overflow:hidden;}
  .progress-bar-fill{ height:100%; background:linear-gradient(90deg,var(--accent),var(--primary)); border-radius:10px; transition:width .4s; }
  .progress-label{ font-size:0.8rem; color:var(--muted); margin-top:6px; }

  /* Badges */
  .badges-grid{ display:grid; grid-template-columns:repeat(4,1fr); gap:12px; }
  .badge{
    text-align:center; padding:14px 6px; border-radius:14px; background:#F7F6FF;
    opacity:0.35; filter:grayscale(1); transition:.3s;
  }
  .badge.unlocked{ opacity:1; filter:none; background:linear-gradient(135deg,#FFF9EC,#FFF3D6); box-shadow:0 4px 14px rgba(255,176,32,0.25);}
  .badge .icon{ font-size:1.8rem; }
  .badge .name{ font-size:0.72rem; font-weight:700; margin-top:6px; }

  /* Log */
  .log-form{ display:flex; gap:10px; margin-bottom:16px; flex-wrap:wrap;}
  .log-form input{
    flex:1; padding:12px 14px; border-radius:12px; border:2px solid #E3E1FF; font-size:0.95rem; min-width:150px;
  }
  .log-form input:focus{ outline:none; border-color:var(--primary);}
  .session-list{ list-style:none; max-height:220px; overflow-y:auto; }
  .session-list li{
    display:flex; justify-content:space-between; padding:10px 0; border-bottom:1px solid #F0EEFF; font-size:0.9rem;
  }
  .session-list li:last-child{ border-bottom:none; }
  .tag{ color:var(--muted); font-size:0.8rem; }

  /* Toast */
  #toast{
    position:fixed; bottom:24px; left:50%; transform:translateX(-50%) translateY(120px);
    background:linear-gradient(135deg,var(--primary),var(--accent)); color:white; padding:16px 28px;
    border-radius:16px; font-weight:700; box-shadow:0 10px 30px rgba(0,0,0,0.2);
    transition:transform .4s cubic-bezier(.2,1.4,.4,1); z-index:100; text-align:center; max-width:90%;
  }
  #toast.show{ transform:translateX(-50%) translateY(0); }

  .quote-box{
    text-align:center; font-style:italic; color:var(--primary-dark); padding:14px; background:#F7F6FF;
    border-radius:14px; margin-top:10px; font-size:0.95rem;
  }

  footer{ text-align:center; padding:24px; color:var(--muted); font-size:0.85rem; }

  /* Homework upload */
  .upload-zone{
    border:2px dashed #D8D4FF; border-radius:16px; padding:26px; text-align:center; cursor:pointer;
    transition:.2s; background:#FBFAFF;
  }
  .upload-zone:hover{ border-color:var(--primary); background:#F5F3FF; }
  .upload-zone input{ display:none; }
  .hw-grid{ display:grid; grid-template-columns:repeat(auto-fill,minmax(90px,1fr)); gap:10px; margin-top:16px; }
  .hw-item{ position:relative; border-radius:12px; overflow:hidden; aspect-ratio:1; cursor:pointer; border:2px solid transparent; transition:.2s; }
  .hw-item.selected{ border-color:var(--primary); }
  .hw-item img{ width:100%; height:100%; object-fit:cover; display:block; }
  .hw-item .del{ position:absolute; top:2px; right:2px; background:rgba(0,0,0,0.55); color:white; border:none; border-radius:50%; width:20px; height:20px; font-size:0.7rem; cursor:pointer; line-height:1; }
  .hw-item .name{ position:absolute; bottom:0; left:0; right:0; background:rgba(0,0,0,0.55); color:white; font-size:0.6rem; padding:2px 4px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }

  /* Study methods */
  .methods-grid{ display:grid; grid-template-columns:repeat(2,1fr); gap:14px; }
  @media (max-width:600px){ .methods-grid{ grid-template-columns:1fr; } }
  .method-card{
    border-radius:16px; padding:18px; background:#F7F6FF; cursor:pointer; transition:.2s; position:relative;
    border:2px solid transparent;
  }
  .method-card:hover{ transform:translateY(-3px); box-shadow:0 8px 20px rgba(108,92,231,0.15); }
  .method-card.active-method{ border-color:var(--primary); background:#EFEBFF; }
  .method-card .m-icon{ font-size:1.6rem; }
  .method-card .m-name{ font-weight:700; margin-top:6px; font-size:0.95rem; }
  .method-card .m-desc{ font-size:0.78rem; color:var(--muted); margin-top:4px; }
  .premium-tag{
    position:absolute; top:10px; right:10px; background:linear-gradient(135deg,#FFB020,#FF8C42); color:white;
    font-size:0.62rem; font-weight:800; padding:3px 8px; border-radius:20px; letter-spacing:0.4px;
  }
  .method-card.locked{ opacity:0.75; }
  .method-card.locked:hover{ opacity:1; }

  .study-panel{ margin-top:20px; padding-top:16px; border-top:1px solid #F0EEFF; }
  .flashcard{
    background:linear-gradient(135deg,#fff,#F7F6FF); border-radius:16px; padding:30px 20px; text-align:center;
    min-height:120px; display:flex; align-items:center; justify-content:center; font-size:1.1rem; font-weight:600;
    cursor:pointer; box-shadow:0 6px 18px rgba(108,92,231,0.1); user-select:none;
  }
  .flash-controls{ display:flex; justify-content:center; gap:10px; margin-top:14px; }
  .quiz-q{ font-weight:700; margin-bottom:12px; }
  .quiz-opt{ display:block; width:100%; text-align:left; padding:12px 14px; margin-bottom:8px; border-radius:10px; border:2px solid #E3E1FF; background:white; cursor:pointer; font-size:0.9rem; }
  .quiz-opt:hover{ border-color:var(--primary); }
  .quiz-opt.correct{ border-color:var(--accent); background:#E9FFF7; }
  .quiz-opt.wrong{ border-color:#FF6B6B; background:#FFECEC; }
  textarea.summary-box{ width:100%; min-height:120px; padding:12px; border-radius:12px; border:2px solid #E3E1FF; font-family:inherit; font-size:0.9rem; resize:vertical; }

  /* Premium modal */
  .modal-overlay{ position:fixed; inset:0; background:rgba(45,42,74,0.55); display:none; align-items:center; justify-content:center; z-index:200; padding:20px; }
  .modal-overlay.show{ display:flex; }
  .modal-box{ background:white; border-radius:20px; padding:32px; max-width:420px; width:100%; text-align:center; position:relative; }
  .modal-box .close-x{ position:absolute; top:14px; right:16px; background:none; border:none; font-size:1.3rem; cursor:pointer; color:var(--muted); }
  .price-tag{ font-size:2.2rem; font-weight:800; color:var(--primary-dark); margin:10px 0; }
  .price-tag span{ font-size:1rem; font-weight:600; color:var(--muted); }
  .perk-list{ text-align:left; margin:16px 0; list-style:none; }
  .perk-list li{ padding:6px 0; font-size:0.9rem; }
  .badge-premium-crown{ font-size:2.2rem; }
</style>
</head>
